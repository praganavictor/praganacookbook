<h1><%= @cuisine.name %></h1>
<%= link_to "Editar", edit_cuisine_path(@cuisine) %>
<% @recipe.each do |r| %>
  <h1><%= r.title %></h1>
  <ul>
    <li><%= r.recipe_type.name %></li>
    <li><%= r.cuisine.name %></li>
    <li><%= r.difficulty %></li>
    <li><%= r.cook_time %> minutos</li>
  </ul>
<% end %>

<% if @recipe.empty? %>
  <p>Nenhuma receita encontrada para este tipo de cozinha</p>
<% end %>

<%= link_to "Voltar", root_path %>
