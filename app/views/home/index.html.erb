<h1><b>CookBook</b></h1>
<p>Bem-vindo ao maior livro de receitas online</p>

<% if flash[:notice] %>
  <p><%= flash[:notice] %></p>
<% end %>

<%= link_to "Enviar uma receita", new_recipe_path %>
<br>
<%= link_to "Criar cozinha", new_cuisine_path %>
<hr>

<div class="cuisine">
  <ul>
    <% @cuisines.each do |c| %>
    <h3>Cozinha</h3>
      <li><%= link_to c.name, cuisine_path(c.id)%></li>
    <% end %>
  </ul>
</div>

<div class="recipe_type">
  <ul>
    <% @recipe_types.each do |rt| %>
      <h3>Receitas por tipo</h3>
      <li><%= link_to rt.name, recipe_type_path(rt.id) %></li>
    <% end %>
  </ul>
</div>

<hr>

<% @recipes.each do |r| %>
  <ul>
    <li><h1><%= link_to r.title, recipe_path(r.id) %></h1></li>
    <li><%= r.recipe_type.name %></li>
    <li><%= r.cuisine.name %></li>
    <li><%= r.difficulty %></li>
    <li><%= r.cook_time %> minutos</li>
  </ul>

  </tr>
<% end %>
