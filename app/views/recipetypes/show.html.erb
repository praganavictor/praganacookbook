<h1><%= @recipe_types.name %></h1>

<% @recipe.each do |r| %>
  <h1><%= r.title %></h1>
  <ul>
    <li><%= r.recipe_type.name %></li>
    <li><%= r.cuisine.name %></li>
    <li><%= r.difficulty %></li>
    <li><%= r.cook_time %> minutos</li>
  </ul>
<% end %>

<% if @recipe.empty? %>
  <p>Nenhuma receita encontrada para este tipo de receitas</p>
<% end %>

<%= link_to "Voltar", root_path %>
